<%
const fmtN   = (n) => new Intl.NumberFormat('en-US').format(n || 0);
const fmtTs  = (t) => t ? new Date(t * 1000).toISOString().replace('T', ' ').slice(0, 19) + 'Z' : '—';
const ago = (t) => {
    if (!t) return '—';
    const s = Math.max(0, Math.floor(Date.now() / 1000) - t);
    if (s < 60) return s + 's ago';
    if (s < 3600) return Math.floor(s / 60) + 'm ago';
    if (s < 86400) return Math.floor(s / 3600) + 'h ago';
    return Math.floor(s / 86400) + 'd ago';
};
const fmtSats = (sats) => {
    if (!sats) return '0 sats';
    const btc = sats / 1e8;
    if (btc >= 0.01) return fmtN(sats) + ' sats (' + btc.toFixed(8) + ' BTC)';
    return fmtN(sats) + ' sats';
};
%>
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="refresh" content="15">
    <title>admin · simplepool</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <header class="top">
        <a href="/" class="brand">simplepool</a>
        <span class="tag">pool operator</span>
    </header>
    <main class="wrap">
        <section class="card info">
            <h2>Pool operator view</h2>
            <p class="muted small">
                The <em>read</em> half of this page is a live probe of Thunder
                plus the pool's SQLite ledger. The <em>Operator actions</em>
                card below is the write half — every button POSTs to a
                CSRF-gated route and redirects here with a flash message.
                See <code>payout/README.md</code> for the runbook when things
                get weird.
            </p>
        </section>

        <% if (flash) { %>
        <section class="card" style="border-left:4px solid <%= flash.ok ? '#5b8' : '#c66' %>">
            <h2 style="color:<%= flash.ok ? '#5b8' : '#c66' %>">
                <%= flash.ok ? '✓' : '✗' %> <%= flash.msg %>
            </h2>
            <% if (flash.detail) { %>
                <p class="mono small" style="margin:0;word-break:break-all"><%= flash.detail %></p>
            <% } %>
        </section>
        <% } %>

        <section class="card">
            <h2>Operator actions</h2>
            <p class="muted small" style="margin-top:0">
                CSRF-protected POST forms. Each action returns you here with
                a green ✓ or red ✗ flash. All four are safe to fire multiple
                times — Thunder / the payout worker will report the truth if
                the state hasn't changed.
            </p>

            <div class="grid" style="align-items:start">

                <!-- Action #4: nudge mine -->
                <form method="POST" action="/admin/action/nudge-mine"
                      style="padding:0.5em 0;border-bottom:1px solid #0002">
                    <input type="hidden" name="csrf" value="<%= csrfToken %>">
                    <label style="display:block;margin-bottom:0.25em"><strong>Nudge Thunder</strong></label>
                    <p class="muted small" style="margin:0 0 0.5em 0">
                        Call <code>mine</code> once. Thunder builds a fresh
                        BMM commit if it can; harmless if it can't.
                    </p>
                    <button type="submit">Nudge mine</button>
                </form>

                <!-- Action #2: trigger payout -->
                <form method="POST" action="/admin/action/trigger-payout"
                      style="padding:0.5em 0;border-bottom:1px solid #0002">
                    <input type="hidden" name="csrf" value="<%= csrfToken %>">
                    <label style="display:block;margin-bottom:0.25em"><strong>Trigger payout cycle</strong></label>
                    <p class="muted small" style="margin:0 0 0.5em 0">
                        Ask the payout worker to run one cycle now instead
                        of waiting for its next tick.
                        <% if (!payoutAdminConfigured) { %>
                            <br><em style="color:#c66">Not configured — set <code>PAYOUT_ADMIN_URL</code>.</em>
                        <% } %>
                    </p>
                    <button type="submit" <%= payoutAdminConfigured ? '' : 'disabled' %>>Trigger now</button>
                </form>

                <!-- Action #3: remove from mempool -->
                <form method="POST" action="/admin/action/remove-from-mempool"
                      style="padding:0.5em 0;border-bottom:1px solid #0002">
                    <input type="hidden" name="csrf" value="<%= csrfToken %>">
                    <label style="display:block;margin-bottom:0.25em"><strong>Remove stale Thunder tx</strong></label>
                    <p class="muted small" style="margin:0 0 0.5em 0">
                        Drop a stuck tx from Thunder's mempool. Use when a
                        payout keeps failing with <code>utxo double spent</code>
                        because a phantom tx is holding the reserve UTXO.
                    </p>
                    <input type="text" name="txid" placeholder="64-char hex txid"
                           pattern="[0-9a-fA-F]{64}" required
                           style="width:100%;font-family:monospace;padding:0.35em;margin-bottom:0.5em">
                    <button type="submit">Remove from mempool</button>
                </form>

                <!-- Action #1: BTC → Thunder deposit -->
                <form method="POST" action="/admin/action/deposit"
                      style="padding:0.5em 0">
                    <input type="hidden" name="csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="sidechain_id" value="<%= reserveSidechainId %>">
                    <label style="display:block;margin-bottom:0.25em"><strong>Deposit BTC → Thunder reserve</strong></label>
                    <p class="muted small" style="margin:0 0 0.5em 0">
                        Spend enforcer-wallet BTC into a Thunder deposit
                        (sidechain #<%= reserveSidechainId %>).
                        <% if (enforcer.ok) { %>
                            <br><strong>Spendable now:</strong> <%= fmtSats(enforcer.confirmed_sats) %>
                            <% if (enforcer.pending_sats > 0) { %>
                                (+<%= fmtSats(enforcer.pending_sats) %> pending)
                            <% } %>
                        <% } %>
                    </p>
                    <label class="small muted">Recipient (Thunder address)</label>
                    <input type="text" name="address" value="<%= reserveAddress === '(unset)' ? '' : reserveAddress %>"
                           required minlength="8" maxlength="128"
                           style="width:100%;font-family:monospace;padding:0.35em;margin-bottom:0.35em">
                    <label class="small muted">Value (sats)</label>
                    <input type="number" name="value_sats" min="1" step="1" required
                           placeholder="e.g. 100000000 for 1 BTC"
                           style="width:100%;padding:0.35em;margin-bottom:0.35em">
                    <label class="small muted">Fee (sats)</label>
                    <input type="number" name="fee_sats" min="0" step="1" value="100"
                           style="width:100%;padding:0.35em;margin-bottom:0.5em">
                    <button type="submit">Submit deposit</button>
                </form>

            </div>
        </section>

        <section class="card">
            <h2>Thunder reserve</h2>
            <% if (reserve.ok) { %>
                <div class="grid">
                    <div><label>Available</label><strong><%= fmtSats(reserve.available_sats) %></strong></div>
                    <div><label>Total</label><strong><%= fmtSats(reserve.total_sats) %></strong></div>
                </div>
                <p class="mono small muted" style="margin-top:0.5em;word-break:break-all"><%= reserveAddress %></p>
            <% } else { %>
                <p class="muted">Thunder RPC unreachable: <em><%= reserve.error %></em></p>
                <p class="mono small muted" style="margin-top:0.5em;word-break:break-all"><%= reserveAddress %></p>
            <% } %>
        </section>

        <section class="card">
            <h2>Pool BTC (enforcer wallet)</h2>
            <p class="muted small" style="margin-top:0">
                Spendable balance the <strong>Deposit BTC → Thunder</strong>
                action can draw from. Fund it by sending BTC to a fresh
                enforcer address (<code>CreateNewAddress</code>) from your
                operator wallet.
            </p>
            <% if (enforcer.ok) { %>
                <div class="grid">
                    <div><label>Confirmed (spendable)</label><strong><%= fmtSats(enforcer.confirmed_sats) %></strong></div>
                    <div><label>Pending (in mempool)</label><strong><%= fmtSats(enforcer.pending_sats) %></strong></div>
                    <div><label>Synced?</label><strong><%= enforcer.has_synced ? '✓' : '✗' %></strong></div>
                </div>
            <% } else { %>
                <p class="muted">Enforcer gRPC unreachable: <em><%= enforcer.error %></em></p>
            <% } %>
        </section>

        <section class="card">
            <h2>PPS ledger totals</h2>
            <div class="grid">
                <div><label>Owed (needs payout)</label><strong><%= fmtSats(totals.owed) %></strong></div>
                <div><label>Accrued (all time)</label><strong><%= fmtSats(totals.accrued) %></strong></div>
                <div><label>Paid (all time)</label><strong><%= fmtSats(totals.paid) %></strong></div>
                <div><label>Workers with a balance</label><strong><%= fmtN(totals.workers) %></strong></div>
            </div>
            <% if (reserve.ok && totals.owed > reserve.available_sats) { %>
                <p class="muted small" style="margin-top:0.75em;color:#c66">
                    ⚠ Reserve is short by
                    <%= fmtSats(totals.owed - reserve.available_sats) %>.
                    The payout worker will keep skipping ticks until this is closed
                    (deposit BTC into the reserve via the two-step deposit service).
                </p>
            <% } %>
        </section>

        <section class="card">
            <h2>Per-worker balances</h2>
            <% if (workers.length === 0) { %>
                <p class="muted">No workers have a PPS balance yet.</p>
            <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Worker</th>
                        <th>Thunder address</th>
                        <th>Owed</th>
                        <th>Accrued</th>
                        <th>Paid</th>
                        <th>Updated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% workers.forEach(w => { %>
                    <tr>
                        <td class="mono small"><%= w.worker_name %></td>
                        <td class="mono small"><%= w.thunder_address %></td>
                        <td><strong><%= fmtSats(w.owed) %></strong></td>
                        <td><%= fmtSats(w.accrued) %></td>
                        <td><%= fmtSats(w.paid) %></td>
                        <td class="muted small" title="<%= fmtTs(w.last_updated) %>"><%= ago(w.last_updated) %></td>
                        <td><a href="/admin/worker/<%= w.worker_id %>" class="small">audit →</a></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>
        </section>

        <section class="card">
            <h2>In-flight payouts</h2>
            <% if (inFlight.length === 0) { %>
                <p class="muted">Nothing in flight — clean.</p>
            <% } else { %>
            <p class="muted small">
                Rows here need operator attention. Empty <em>txid</em>
                means the Thunder broadcast may not have gone out; a
                set <em>txid</em> means the broadcast succeeded but the
                DB finalize crashed. Never auto-resolved.
            </p>
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Worker</th>
                        <th>Amount</th>
                        <th>Age</th>
                        <th>txid</th>
                        <th>State</th>
                    </tr>
                </thead>
                <tbody>
                    <% inFlight.forEach(r => { %>
                    <tr>
                        <td><%= r.id %></td>
                        <td class="mono small"><%= r.worker_name %></td>
                        <td><%= fmtSats(r.sats) %></td>
                        <td class="muted small" title="<%= fmtTs(r.started_at) %>"><%= ago(r.started_at) %></td>
                        <td class="mono small"><%= r.txid || '—' %></td>
                        <td><%= r.txid ? 'broadcast, finalize pending' : 'unbroadcast' %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>
        </section>

        <section class="card">
            <h2>Recent payouts (Thunder)</h2>
            <% if (payouts.length === 0) { %>
                <p class="muted">No successful payouts yet. Populates once the payout worker sends a Thunder tx (or after a manual reconcile).</p>
            <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Worker</th>
                        <th>Amount</th>
                        <th>Fee</th>
                        <th>Thunder txid</th>
                        <th>Note</th>
                    </tr>
                </thead>
                <tbody>
                    <% payouts.forEach(p => { %>
                    <tr>
                        <td class="muted small" title="<%= fmtTs(p.paid_at) %>"><%= ago(p.paid_at) %></td>
                        <td class="mono small"><a href="/admin/worker/<%= p.worker_id %>"><%= p.worker_name %></a></td>
                        <td><strong><%= fmtSats(p.sats) %></strong></td>
                        <td class="muted small"><%= fmtSats(p.fee_sats) %></td>
                        <td class="mono small" title="<%= p.txid %>"><%= p.txid.slice(0,16) %>…<%= p.txid.slice(-6) %></td>
                        <td class="muted small"><%= p.note || '' %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>
        </section>

        <section class="card">
            <h2>Deposits (mainchain → Thunder)</h2>
            <% if (deposits.length === 0) { %>
                <p class="muted">No deposits recorded. See <code>OPERATOR_GUIDE.md</code> or use <code>scripts/log-deposit.sh</code> after issuing a CreateDepositTransaction.</p>
            <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Amount</th>
                        <th>Fee</th>
                        <th>Thunder recipient</th>
                        <th>Mainchain txid</th>
                        <th>Ctip seq</th>
                    </tr>
                </thead>
                <tbody>
                    <% deposits.forEach(d => { %>
                    <tr>
                        <td class="muted small" title="<%= fmtTs(d.ts) %>"><%= ago(d.ts) %></td>
                        <td><strong><%= fmtSats(d.sats_deposited) %></strong></td>
                        <td class="muted small"><%= fmtSats(d.fee_sats) %></td>
                        <td class="mono small"><%= d.thunder_recipient %></td>
                        <td class="mono small" title="<%= d.btc_txid %>"><%= d.btc_txid.slice(0,16) %>…<%= d.btc_txid.slice(-6) %></td>
                        <td class="muted small"><%= d.ctip_seq_before %> → <%= d.ctip_seq_after %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>
        </section>

        <section class="card">
            <h2>Recent blocks (coinbase → pool BTC wallet)</h2>
            <% if (blocks.length === 0) { %>
                <p class="muted">No blocks recorded yet.</p>
            <% } else { %>
            <p class="muted small" style="margin-top:0">
                Every block's coinbase pays the pool's <code>pool_btc_address</code> (in pps-classic
                mode) for <em>reward</em>. Operator batches accumulated BTC into Thunder via the
                deposits above. To see the coinbase txid on-chain:
                <code>bitcoin-cli getblock &lt;hash&gt; 2</code>.
            </p>
            <table>
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Height</th>
                        <th>Block hash</th>
                        <th>Finder</th>
                        <th>Reward</th>
                        <th>Fee</th>
                    </tr>
                </thead>
                <tbody>
                    <% blocks.forEach(b => { %>
                    <tr>
                        <td class="muted small" title="<%= fmtTs(b.ts) %>"><%= ago(b.ts) %></td>
                        <td><%= fmtN(b.height) %></td>
                        <td class="mono small" title="<%= b.hash %>"><%= b.hash.slice(0,16) %>…<%= b.hash.slice(-6) %></td>
                        <td class="mono small">
                            <% if (b.finder_id) { %>
                                <a href="/admin/worker/<%= b.finder_id %>"><%= b.finder_name || b.finder_address || 'unknown' %></a>
                            <% } else { %>
                                <span class="muted">(unattributed)</span>
                            <% } %>
                        </td>
                        <td><%= fmtSats(b.reward_sats) %></td>
                        <td class="muted small"><%= fmtSats(b.fee_sats) %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>
        </section>
    </main>
    <footer class="foot">
        <span>read-only · auto-refresh 15s</span>
        <span class="sep">·</span>
        <span>pool operator view</span>
    </footer>
</body>
</html>
