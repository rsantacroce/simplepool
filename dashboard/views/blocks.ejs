<%
const shortHash = (h) => h ? (h.slice(0, 10) + '…' + h.slice(-8)) : '—';
const shortAddr = (a) => a ? (a.length > 18 ? a.slice(0, 10) + '…' + a.slice(-6) : a) : '—';
%>
<!doctype html>
<html lang="en">
<head>
<%- include('partial/head', { title: 'blocks · simplepool', refresh: 60 }) %>
</head>
<body>
<%- include('partial/nav-public', { active: 'blocks' }) %>
<main class="wrap">
        <section class="card">
            <h2>Blocks found by the pool</h2>
            <% if (rows.length === 0) { %>
                <p class="muted">No blocks recorded yet.</p>
            <% } else { %>
            <table class="lb">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Height</th>
                        <th>Finder</th>
                        <th>Payout address</th>
                        <th>Reward</th>
                        <th>Operator fee</th>
                        <th>Hash</th>
                    </tr>
                </thead>
                <tbody>
                <% rows.forEach(b => { %>
                    <tr>
                        <td title="<%= fmtTs(b.ts) %>"><%= ago(b.ts) %></td>
                        <td><%= fmtN(b.height) %></td>
                        <td>
                            <% if (b.finder) { %>
                                <a href="/worker/<%= encodeURIComponent(b.finder) %>"><%= b.finder %></a>
                            <% } else { %>—<% } %>
                        </td>
                        <td class="mono small" title="<%= b.finder_address || '' %>"><%= shortAddr(b.finder_address) %></td>
                        <td><%= fmtBtc(b.reward_sats) %></td>
                        <td><%= fmtBtc(b.fee_sats) %></td>
                        <td class="mono small" title="<%= b.hash %>"><%= shortHash(b.hash) %></td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
            <p class="muted small">
                <% if (next_before) { %>
                    <a href="/blocks?before=<%= next_before %>">← older</a>
                <% } %>
            </p>
            <% } %>
        </section>

        <p><a href="/">← back to overview</a></p>
    </main>
    <footer class="foot">
        <span>read-only · auto-refresh 60s</span>
        <span class="sep">·</span>
        <span>built by Layer Two Labs team</span>
        <span class="sep">·</span>
        <a href="https://github.com/LayerTwo-Labs/simplepool" target="_blank" rel="noopener">source on GitHub</a>
    </footer>
    <script src="/static/script.js" defer></script>
</body>
</html>
